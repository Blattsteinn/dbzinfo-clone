
<% @card.specials.each do |special| %>
    <% unless special.name.include? "(Extreme)" %>
        <div class="super-attacks">

            <div class="header-section"> 
                <div class="header-section-text super-attack-header"> 

                    <p> <%= special.get_actual_super_name(special.style) %> 
                    (<%=special.eball_num_start %> Ki) |</p>

                    <div style="display: flex;">
                        <div class="super-attack-image"> 
                            <%= image_tag special.get_special_image(special.special_category_name) %>
                        </div>
                        <p> <%= special.name %> </p> 
                    </div>
                   
                </div>
            </div>

            <div class="information-section">
                <div>
                    <p class="information-section-text"> 
                        <%= special.description %>
                    </p>
                    
                </div>


                <% unless special.special_bonus_1_lv.to_s == "0" %>
                <hr>
                <div>
                    <p class="information-section-text">
                        <b> At level <%= special.special_bonus_1_lv %>: </b>
                        <%= special.special_bonus_1 %>
                    </p>
                </div>
                <% end %>   
            </div>
            
        </div>
    <% end %>
<% end %>