
<div class="application-main-display-box">
    <div id="main-display-box-header"> Links 
    </div>

    <div id="search-bar">
            <%= form_with url: links_path, method: :get, local: true do |f| %>
                <%= f.text_field :search, placeholder: "Search links...", id: "search-input" %>
                <%= f.submit "Search", id: "search-submit" %>
            <% end %>
    </div>

    <div class = "lc-container">
        <% @links.each do |link| %>
            <div>
                <%= render 'link', link: link %>
            </div>
        <% end %>
    </div> 

